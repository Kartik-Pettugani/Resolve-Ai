# Gemini API Configuration
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Configuration (Optional fallback)
GROQ_API_KEY=your_groq_api_key_here

# Turso Database Configuration
TURSO_DATABASE_URL=libsql://your-database-name.turso.io
TURSO_AUTH_TOKEN=your_turso_auth_token_here

# Qdrant Configuration (Optional — falls back to Turso for vector search)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# JWT Configuration
JWT_SECRET=your_jwt_secret_here

# Rate Limiting (Optional — applies to /api/chat and /api/documents/ingest/*)
# Max requests allowed per client (per IP) within the window. Default: 20
RATE_LIMIT_MAX=20
# Sliding window length in milliseconds. Default: 60000 (1 minute)
RATE_LIMIT_WINDOW_MS=60000
